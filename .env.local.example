# ── App URL ────────────────────────────────────────────────────────────────────
# Production : https://www.viralynz.com (recommandé — même URL que le domaine public).
# Si absent en prod Vercel, le code utilise https://www.viralynz.com par défaut
# (évite les liens email qui pointent vers *.vercel.app).
# Local : http://localhost:3000
#
# Supabase → Authentication → URL Configuration :
#   Site URL : https://www.viralynz.com
#   Redirect URLs (ajouter chaque ligne) :
#     https://www.viralynz.com/auth/callback
#     https://www.viralynz.com/reset-password
#     http://localhost:3000/auth/callback
#     http://localhost:3000/reset-password
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — KEEP SECRET, server-only, never commit
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT session secret ─────────────────────────────────────────────────────────
# Any random string of at least 32 characters
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe (abonnements MRR) ────────────────────────────────────────────────────
# Clés : https://dashboard.stripe.com/apikeys — test (sk_test_…) ou live (sk_live_…)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret — Developers → Webhooks → endpoint https://…/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Prix récurrents Stripe (Products → Add price → Recurring).
STRIPE_PRICE_CREATOR_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...
# Ancien alias Pro conservé pour certains environnements locaux.
STRIPE_PRICE_PRO=price_...
# Affichage UI : montants dans lib/stripe-pricing.ts (EUR affiché)

# ── TikTok Login Kit (OAuth) — optionnel — lier le compte TikTok au dashboard ──
# Crée une app sur https://developers.tiktok.com/ → ajoute le produit « Login Kit ».
# Redirect URI à enregistrer (exactement, avec le bon host) :
#   http://localhost:3000/api/tiktok/callback
#   https://www.viralynz.com/api/tiktok/callback   (prod)
# Scope utilisé dans le code : user.info.basic
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Trend Intelligence / Radar tendances
# APIFY_TOKEN reste serveur-only. Ne jamais prefixer en NEXT_PUBLIC.
APIFY_TOKEN=
APIFY_TIKTOK_TRENDS_ACTOR_ID=
APIFY_TIKTOK_SEARCH_ACTOR_ID=
APIFY_TIKTOK_HASHTAG_ACTOR_ID=
TREND_SCAN_COUNTRIES=FR,BE,CA
TREND_SCAN_LANGUAGE=fr
TREND_SCAN_DEFAULT_NICHES=business,coaching,ecommerce,creator_growth,fitness,beauty,education,lifestyle
TREND_SCAN_MAX_ITEMS=100
TREND_SCAN_CACHE_MINUTES=180
CRON_SECRET=
# Local uniquement : affiche un badge Mode demo et utilise un petit echantillon local si Apify est absent.
NEXT_PUBLIC_TRENDS_DEMO_MODE=false
