# ── App URL ────────────────────────────────────────────────────────────────────
# REQUIRED — Used for Supabase email confirmation redirect links.
# • Local dev  → http://localhost:3000
# • Production → https://your-app.vercel.app   (set in Vercel Dashboard)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — KEEP SECRET, server-only, never commit
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── JWT session secret ─────────────────────────────────────────────────────────
# Any random string of at least 32 characters
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# Optional — local dev ONLY (comma-separated emails). Makes getUserById show Elite in UI.
# Leave unset in production — otherwise dashboard and APIs disagree on the real plan.
# DEV_FORCE_ELITE_EMAILS=test@example.com

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret — Stripe Dashboard > Developers > Webhooks
# Endpoint URL to register: https://your-app.vercel.app/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
